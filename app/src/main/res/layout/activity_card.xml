<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_full_brown"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== HEADER BANNER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_brown"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"
            android:elevation="4dp">

            <!-- Top row: greeting + settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/SelamatPagi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Selamat_Pagi"
                        android:textColor="@color/colorOnPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/Teks2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/siap_melayani_pelanggan"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_settings"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/colorOnPrimary"/>
            </LinearLayout>

            <!-- ===== PENDAPATAN HARI INI (BESAR) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#33FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰  Pendapatan Hari Ini"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvTodayIncome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/colorOnPrimary"
                        android:textSize="32sp"
                        android:textStyle="bold"/>

                    <!-- 4 stat chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvTodayTrx"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/colorOnPrimary"
                                android:textStyle="bold"
                                android:textSize="18sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trx Hari Ini"
                                android:textColor="#CCFFFFFF"
                                android:textSize="10sp"
                                android:gravity="center"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#33FFFFFF"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvTotalProduk"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/colorOnPrimary"
                                android:textStyle="bold"
                                android:textSize="18sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Produk"
                                android:textColor="#CCFFFFFF"
                                android:textSize="10sp"
                                android:gravity="center"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#33FFFFFF"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvTotalPelanggan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/colorOnPrimary"
                                android:textStyle="bold"
                                android:textSize="18sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pelanggan"
                                android:textColor="#CCFFFFFF"
                                android:textSize="10sp"
                                android:gravity="center"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#33FFFFFF"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/transaction"
                                app:tint="@color/colorOnPrimary"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aktif"
                                android:textColor="#CCFFFFFF"
                                android:textSize="10sp"
                                android:gravity="center"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ===== TOMBOL KASIR POS (utama & menonjol) ===== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKasirPOS"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:text="🛒  BUKA KASIR POS"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:cornerRadius="18dp"
            app:backgroundTint="#BF360C"
            app:icon="@drawable/transaction"
            app:iconTint="@android:color/white"
            app:iconSize="22dp"
            app:iconPadding="12dp"/>

        <!-- ===== RINGKASAN ANALYTICS ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTitleEstimasi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ringkasan_hari_ini"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Laporan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivLaporan"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/resume"
                            app:tint="@color/colorSecondary"/>

                        <TextView
                            android:id="@+id/tvLaporan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/laporan"
                            android:textColor="@color/colorOnSurface"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="8dp"
                        android:background="@color/colorDivider"/>

                    <!-- Pelanggan -->
                    <LinearLayout
                        android:id="@+id/llPelanggan"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/ivPelanggan"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_pelanggan"
                            app:tint="@color/colorPrimaryVariant"/>

                        <TextView
                            android:id="@+id/tvPelanggan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Pelanggan"
                            android:textColor="@color/colorOnSurface"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SECTION TITLE: Menu Utama ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:text="Menu Utama"
            android:textColor="@color/colorOnPrimary"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <!-- ===== GRID MENU (3 cols × 3 rows) ===== -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:columnCount="3"
            android:rowCount="3"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <!-- Profil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorSurface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/img2" android:layout_width="34dp"
                        android:layout_height="34dp" android:src="@drawable/profile"
                        app:tint="@color/colorPrimaryVariant"/>
                    <TextView android:id="@+id/txt2" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:text="@string/profil" android:textColor="@color/colorOnSurface"
                        android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Produk -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorSurface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/img3" android:layout_width="34dp"
                        android:layout_height="34dp" android:src="@drawable/product"
                        app:tint="@color/colorPrimaryVariant"/>
                    <TextView android:id="@+id/txt3" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:text="@string/produk" android:textColor="@color/colorOnSurface"
                        android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Kategori -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorSurface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/img4" android:layout_width="34dp"
                        android:layout_height="34dp" android:src="@drawable/category"
                        app:tint="@color/colorPrimaryVariant"/>
                    <TextView android:id="@+id/txt4" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:text="@string/kategori" android:textColor="@color/colorOnSurface"
                        android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pegawai -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorSurface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/img5" android:layout_width="34dp"
                        android:layout_height="34dp" android:src="@drawable/employee"
                        app:tint="@color/colorPrimaryVariant"/>
                    <TextView android:id="@+id/txt5" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:text="@string/pegawai" android:textColor="@color/colorOnSurface"
                        android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cabang -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorSurface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/img6" android:layout_width="34dp"
                        android:layout_height="34dp" android:src="@drawable/branch"
                        app:tint="@color/colorPrimaryVariant"/>
                    <TextView android:id="@+id/txt6" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:text="@string/cabang" android:textColor="@color/colorOnSurface"
                        android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mencetak -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card7"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorSurface"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:id="@+id/img7" android:layout_width="34dp"
                        android:layout_height="34dp" android:src="@drawable/print"
                        app:tint="@color/colorPrimaryVariant"/>
                    <TextView android:id="@+id/txt7" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="6dp"
                        android:text="Cetak Laporan" android:textColor="@color/colorOnSurface"
                        android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



        </GridLayout>

        <!-- hidden compat views -->
        <TextView android:id="@+id/teks3" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>