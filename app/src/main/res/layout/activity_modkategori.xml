<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_full_brown"
    tools:context="Kategori.ModKategoriActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/headerModKategori"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_brown"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/arrow"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/colorOnPrimary" />

            <TextView
                android:id="@+id/tvJudulHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tambah_kategori"
                android:textColor="@color/colorOnPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

    <TextView
        android:id="@+id/tvJudul"
        android:layout_marginTop="32dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tambah_kategori"
        android:textColor="@color/colorOnBackground"
        android:gravity="center"
        android:textSize="24sp"
        android:textStyle="bold"/>

    <!-- Nama Kategori -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/nama_kategori">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Status -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/status"
        app:endIconMode="dropdown_menu">

        <AutoCompleteTextView
            android:paddingLeft="10dp"
            android:id="@+id/actStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSimpan"
        android:layout_marginTop="32dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/colorPrimary"
        android:textColor="@color/colorOnPrimary"
        android:textStyle="bold"
        android:text="@string/simpan"/>

    </LinearLayout>
</ScrollView>