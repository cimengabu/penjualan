<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_full_brown">

    <!-- Header Total Saldo - besar dan jelas -->
    <LinearLayout
        android:id="@+id/headerPOS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_brown"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBackPOS"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/arrow"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                app:tint="@color/colorOnPrimary"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Kasir POS"
                android:textColor="@color/colorOnPrimary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/btnClearCart"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                app:tint="@color/colorOnPrimary"/>
        </LinearLayout>

        <!-- Total Belanja Besar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Total Belanja"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvTotalBelanja"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textColor="@color/colorOnPrimary"
            android:textSize="36sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipItemCount"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="0 item"
                app:chipBackgroundColor="#33FFFFFF"
                android:textColor="@color/colorOnPrimary"
                android:textSize="12sp"/>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="BAYAR"
                android:textStyle="bold"
                android:textSize="13sp"
                app:cornerRadius="18dp"
                app:backgroundTint="#FF6F00"
                android:paddingHorizontal="20dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Search Bar Produk -->
    <EditText
        android:id="@+id/etSearchPOS"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_circle_avatar"
        android:backgroundTint="@color/colorSurface"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="10dp"
        android:hint="Cari produk..."
        android:paddingHorizontal="16dp"
        android:textColor="@color/colorOnBackground"
        android:textColorHint="@color/colorTextSecondary"
        android:inputType="text"/>

    <!-- Category filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:paddingHorizontal="12dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupKategori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"/>
    </HorizontalScrollView>

    <!-- Produk Grid + Keranjang side by side on bigger screens, stacked on phones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Katalog Produk Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProdukPOS"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

    </LinearLayout>

    <!-- Bottom Keranjang Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardKeranjang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🛒 Keranjang"
                    android:textColor="@color/colorOnSurface"
                    android:textStyle="bold"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/tvKeranjangCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(0 item)"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvKeranjang"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="true"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
