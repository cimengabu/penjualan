<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_full_brown">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_brown"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBackCheckout"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/arrow"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    app:tint="@color/colorOnPrimary"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Checkout Pembayaran"
                    android:textColor="@color/colorOnPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/total_yang_harus_dibayar"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvTotalCheckout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="@color/colorOnPrimary"
                android:textSize="34sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Order Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 Ringkasan Pesanan"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="15sp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOrderSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/colorDivider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/subtotal"
                        android:textColor="@color/colorTextSecondary"/>
                    <TextView android:id="@+id/tvSubtotalCO" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Rp 0"
                        android:textColor="@color/colorOnSurface"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/diskon"
                        android:textColor="@color/colorTextSecondary"/>
                    <TextView android:id="@+id/tvDiskonCO" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="- Rp 0"
                        android:textColor="#4CAF50"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Pajak (0%)"
                        android:textColor="@color/colorTextSecondary"/>
                    <TextView android:id="@+id/tvPajakCO" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Rp 0"
                        android:textColor="@color/colorOnSurface"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/colorDivider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/total_bayar"
                        android:textStyle="bold" android:textColor="@color/colorOnSurface"
                        android:textSize="15sp"/>
                    <TextView android:id="@+id/tvTotalFinalCO" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Rp 0"
                        android:textStyle="bold" android:textColor="@color/colorPrimary"
                        android:textSize="16sp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pelanggan Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Data Pelanggan"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="15sp"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="Nama Pelanggan (opsional)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNamaPelangganCO"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="No. HP Pelanggan (opsional)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNoHpPelangganCO"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Kasir Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏷️ Kasir Bertugas"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="15sp"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="@string/nama_kasir">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNamaKasir"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Metode Pembayaran -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳 Metode Pembayaran"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="15sp"
                    android:layout_marginBottom="10dp"/>

                <RadioGroup
                    android:id="@+id/rgMetodePembayaran"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbTunai"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="💵  Tunai (Cash)"
                        android:textColor="@color/colorOnSurface"
                        android:buttonTint="@color/colorPrimary"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/rbTransfer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🏦  Transfer Bank"
                        android:textColor="@color/colorOnSurface"
                        android:buttonTint="@color/colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rbQris"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="📱  QRIS / E-Wallet"
                        android:textColor="@color/colorOnSurface"
                        android:buttonTint="@color/colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rbDebit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="💳  Kartu Debit/Kredit"
                        android:textColor="@color/colorOnSurface"
                        android:buttonTint="@color/colorPrimary"/>
                </RadioGroup>

                <!-- Uang Tunai (visible hanya jika Tunai dipilih) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUangTunai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="Nominal Uang Tunai (Rp)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUangTunai"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Kembalian -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardKembalian"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#E8F5E9">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="💵 Kembalian"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"/>
                        <TextView
                            android:id="@+id/tvKembalian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"
                            android:textSize="18sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tombol Proses Pembayaran -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProsesBayar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:text="✅ PROSES PEMBAYARAN"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/colorPrimary"
            android:textColor="@color/colorOnPrimary"/>

    </LinearLayout>
</ScrollView>
