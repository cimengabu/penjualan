<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil Toko"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etNamaToko"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nama Toko"
        android:layout_marginTop="32dp"/>

    <EditText
        android:id="@+id/etAlamatToko"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Alamat Toko"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/etNoTelpToko"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="No Telepon Toko"
        android:inputType="phone"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnSimpanProfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simpan Profil"
        android:layout_marginTop="32dp"/>

</LinearLayout>
