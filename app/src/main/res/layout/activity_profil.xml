<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_full_brown">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header with background photo + avatar overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <!-- Background image (clickable to change) -->
            <ImageView
                android:id="@+id/ivHeaderBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_gradient_brown"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="Ubah foto latar" />

            <!-- Gradient overlay so icons stay visible -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#55000000" />

            <!-- Back arrow top-left -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="12dp"
                android:layout_gravity="start|top"
                android:src="@drawable/arrow"
                app:tint="@color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <!-- Camera hint icon on background -->
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="end|top"
                android:layout_margin="14dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/white"
                android:contentDescription="Ubah latar" />

            <!-- Avatar circle centered at bottom of header -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="-44dp"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Avatar image -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp">

                    <ImageView
                        android:id="@+id/ivAvatarProfil"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:src="@drawable/profile"
                        app:tint="@color/colorOnPrimary"
                        android:scaleType="centerCrop"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_circle_avatar"
                        android:contentDescription="Ubah foto profil" />

                    <!-- Camera badge -->
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="@color/colorPrimary"
                        android:padding="4dp"
                        app:tint="@color/white"
                        android:contentDescription="Ganti foto" />
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Spacer for avatar overlap -->
        <View
            android:layout_width="match_parent"
            android:layout_height="52dp" />

        <!-- Toko Name (big, centered) -->
        <TextView
            android:id="@+id/tvNamaTokoDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/toko_anda"
            android:textColor="@color/colorOnBackground"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/ketuk_avatar_atau_foto_latar_u"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/produk"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary" />
                    <TextView
                        android:id="@+id/tvStatProduk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cabang"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary" />
                    <TextView
                        android:id="@+id/tvStatCabang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pegawai"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary" />
                    <TextView
                        android:id="@+id/tvStatPegawai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Info Form Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/informasi_toko"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextSecondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSimpanProfil"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/simpan"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:backgroundTint="@color/colorPrimary"
                        android:textColor="@color/colorOnPrimary" />
                </LinearLayout>

                <!-- Nama Toko -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    android:hint="@string/nama_toko">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNamaToko"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorOnSurface"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Alamat -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    android:hint="@string/alamat_toko">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAlamatToko"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorOnSurface"
                        android:inputType="textMultiLine"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- No Telepon -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    android:hint="@string/no_telepon_toko">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNoTelpToko"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorOnSurface"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    android:hint="@string/email_toko">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmailToko"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorOnSurface"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Website -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    android:hint="@string/website_media_sosial">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etWebsiteToko"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorOnSurface"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Deskripsi -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    android:hint="@string/deskripsi_toko">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDeskripsiToko"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorOnSurface"
                        android:inputType="textMultiLine"
                        android:minLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:text="@string/keluar_akun"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/colorError"
            android:textColor="@color/colorOnPrimary" />

    </LinearLayout>
</ScrollView>
