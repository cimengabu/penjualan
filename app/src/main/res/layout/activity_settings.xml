<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_full_brown">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.Penjualan">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_gradient_brown"
            app:title="@string/pengaturan"
            app:titleTextColor="@color/colorOnPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Tampilan / Theme -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tampilan_theme"
                android:textColor="@color/colorTextSecondary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchNightMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mode_gelap_night_mode"
                android:textColor="@color/colorOnBackground"
                android:layout_marginBottom="24dp" />

            <!-- Bahasa -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bahasa_language"
                android:textColor="@color/colorTextSecondary"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <RadioGroup
                android:id="@+id/rgLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbIndo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/bahasa_indonesia"
                    android:textColor="@color/colorOnBackground"
                    android:buttonTint="@color/colorPrimary"/>

                <RadioButton
                    android:id="@+id/rbEnglish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/english"
                    android:textColor="@color/colorOnBackground"
                    android:layout_marginTop="8dp"
                    android:buttonTint="@color/colorPrimary"/>
            </RadioGroup>

            <!-- Notifikasi -->

            <!-- Keamanan -->

            <!-- Info -->

            <!-- Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/simpan"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/colorPrimary"
                android:textColor="@color/colorOnPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/keluar_akun"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/colorError"
                android:textColor="@color/colorOnError" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
